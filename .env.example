# Copy to .env in the PROJECT ROOT (same folder as app.js), then restart: npm start

OPENAI_API_KEY=sk-...

# Google OAuth 2.0 (export to the user's own spreadsheet)
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (type: Web application)
# In Google Console, add to BOTH "JavaScript origins" AND "redirect URIs" (no path, no trailing slash):
#   http://localhost:3000
#   http://127.0.0.1:3000
# Consent screen must be in Testing mode for localhost (not Production)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
SESSION_SECRET=use_a_long_random_string_here

# Optional: set if Google Console only accepts 127.0.0.1 (open the app at the same host)
# GOOGLE_CALLBACK_URL=http://127.0.0.1:3000
